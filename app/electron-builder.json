{
  "appId": "org.zoneminder.zmninjang.electron",
  "productName": "zmNinjaNg",
  "extraMetadata": {
    "homepage": "https://github.com/ZoneMinder/zmNinjaNg",
    "description": "ZoneMinder client",
    "license": "Apache-2.0"
  },
  "directories": {
    "output": "../desktop_release_builds/electron"
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.map",
    "electron/**/*",
    "package.json",
    "!node_modules/**/*"
  ],
  "npmRebuild": false,
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.utilities",
    "hardenedRuntime": true,
    "notarize": false,
    "icon": "electron/icons/icon.icns",
    "artifactName": "${productName}_${version}_aarch64.${ext}"
  },
  "linux": {
    "target": ["AppImage", "deb", "rpm"],
    "maintainer": "ZoneMinder <noreply@zoneminder.com>",
    "category": "Utility",
    "icon": "electron/icons/icon.png",
    "artifactName": "${productName}_${version}_${arch}.${ext}"
  },
  "win": {
    "target": ["nsis"],
    "icon": "electron/icons/icon.ico",
    "artifactName": "${productName}_${version}_${arch}.${ext}"
  }
}
